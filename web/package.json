{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "homepage": ".",
  "scripts": {
    "build": "next build",
    "clear-nextjs-cache": "rm -rf ./.next/cache",
    "dev": "export NEXT_PUBLIC_ENVIRONMENT=DEV && yarn serve",
    "disk-space-info": "du -hs ./node_modules && du -hs ./.next && du -hs ./.next/cache",
    "format-changed": "cd .. && git diff $(git merge-base --fork-point main) --name-only --diff-filter=d | xargs npx prettier -w",
    "postinstall": "./scripts/post_install.sh",
    "lint": "npx eslint . --max-warnings 0",
    "lint-fix": "npx eslint . --fix",
    "prettier": "npx prettier --write .",
    "prod": "concurrently -n NEXT,TS -c magenta,cyan \"yarn serve\" \"yarn ts-watch\"",
    "serve": "next dev -H 0.0.0.0 -p 3000",
    "serve:debug": "NODE_OPTIONS='--inspect=0.0.0.0:9229' yarn serve",
    "start": "next start",
    "ts-watch": "tsc --watch --noEmit --incremental --preserveWatchOutput --pretty",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "@floating-ui/dom": "1.7.5",
    "@floating-ui/react": "0.27.18",
    "@floating-ui/react-dom": "2.1.7",
    "@headlessui/react": "2.2.9",
    "@heroicons/react": "2.2.0",
    "@radix-ui/react-slider": "1.3.6",
    "@react-spring/web": "10.0.3",
    "@tiptap/core": "2.10.4",
    "@tiptap/extension-character-count": "2.10.4",
    "@tiptap/extension-image": "2.10.4",
    "@tiptap/extension-link": "2.10.4",
    "@tiptap/extension-mention": "2.10.4",
    "@tiptap/extension-placeholder": "2.10.4",
    "@tiptap/pm": "2.10.4",
    "@tiptap/react": "2.10.4",
    "@tiptap/starter-kit": "2.10.4",
    "@tiptap/suggestion": "2.10.4",
    "@vercel/og": "0.5.20",
    "clsx": "2.1.1",
    "compressorjs": "1.1.1",
    "dayjs": "1.11.19",
    "heic2any": "0.0.4",
    "lodash": "4.17.23",
    "lucide-react": "0.575.0",
    "nanoid": "5.0.9",
    "next": "16.2.3",
    "react": "19.2.3",
    "react-datepicker": "9.1.0",
    "react-dom": "19.2.3",
    "react-expanding-textarea": "2.3.6",
    "react-hook-form": "7.65.0",
    "react-hot-toast": "2.2.0",
    "react-icons": "5.5.0",
    "react-markdown": "10.1.0",
    "recharts": "3.2.1",
    "tailwindcss": "^3.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@next/eslint-plugin-next": "16.1.6",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/container-queries": "0.1.1",
    "@tailwindcss/forms": "0.4.0",
    "@tailwindcss/typography": "^0.5.13",
    "@types/d3": "7.4.0",
    "@types/lodash": "^4.17.0",
    "@types/node": "20.19.35",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.27",
    "concurrently": "8.2.2",
    "cross-env": "7.0.3",
    "eslint": "9.39.3",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-lodash": "7.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.1.4",
    "next-sitemap": "4.2.3",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "prettier-plugin-packagejson": "3.0.0",
    "prettier-plugin-sql": "0.19.2",
    "prettier-plugin-tailwindcss": "0.2.8",
    "ts-node": "10.9.1",
    "tsc-alias": "1.8.2",
    "tsc-files": "1.1.3",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.20.6",
    "typescript": "5.5.4",
    "typescript-eslint": "^8.32.0",
    "wait-on": "9.0.4"
  }
}
